{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "DOCKERFILE",
		"dockerfilePath": "apps/web/Dockerfile",
		"watchPatterns": [
			"apps/web/**",
			"packages/**",
			"i18n/**",
			"pnpm-lock.yaml",
			"pnpm-workspace.yaml",
			"package.json"
		]
	},
	"deploy": {
		"numReplicas": 1,
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 10
	}
}
